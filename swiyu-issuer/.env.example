# Environment variables consumed by swiyu-issuer.
#
# Copy this file to .env in the same directory and adjust values as
# needed. .env is gitignored at the workspace root.
# direnv loads .env automatically on cd via the sibling .envrc.
#
# -----------------------------------------------------------------------------
# Required: database
# -----------------------------------------------------------------------------
#
# DATABASE_URL is what the binary actually reads. The four
# POSTGRES_* variables below it are read by docker-compose.yml so a
# `docker compose up -d` brings up a Postgres matching this URL.
#
# Keep DATABASE_URL consistent with the four POSTGRES_* values: if
# you change a credential, change it in both places. The duplication
# is intentional — the binary uses the standard DATABASE_URL shape
# (the convention production deployments inject), while compose
# requires components.

# PostgreSQL connection string used by the management API and any
# OIDC-side binary. Format:
#   postgres://<user>:<password>@<host>:<port>/<database>
DATABASE_URL=postgres://swiyu_issuer:swiyu_issuer@localhost:5433/swiyu_issuer

# Database connection components — read by docker-compose.yml.
# Compose falls back to these same defaults if .env is absent, so a
# fresh checkout works without copying this file first.
POSTGRES_USER=swiyu_issuer
POSTGRES_PASSWORD=swiyu_issuer
POSTGRES_DB=swiyu_issuer
POSTGRES_HOST_PORT=5433


# -----------------------------------------------------------------------------
# HashiCorp Vault dev container — read by docker-compose.yml
# -----------------------------------------------------------------------------
#
# docker-compose.yml brings up a HashiCorp Vault container in dev
# mode (in-memory, unsealed, single fixed root token) and enables
# the Transit secrets engine. State is wiped on every container
# restart. Used by VaultSigningEngine in development and integration
# tests; production deployments use a real, sealed Vault.

VAULT_DEV_ROOT_TOKEN_ID=dev-only-root
VAULT_HOST_PORT=8200

# Signing-engine backend selected by the binary at startup.
#   dev    — DevSigningEngine, stores private keys unencrypted in
#            Postgres. Default. Suitable for local dev only.
#   vault  — VaultSigningEngine, uses HashiCorp Vault Transit. Reads
#            VAULT_ADDR / VAULT_TOKEN below; private keys never leave
#            Vault.
SIGNING_ENGINE=dev

# VaultSigningEngine — read by the binary when SIGNING_ENGINE=vault.
# VAULT_ADDR and VAULT_TOKEN are required in that mode; the other
# two have defaults baked in.
#
#   VAULT_ADDR                  Base URL of the Vault server, e.g.
#                               http://127.0.0.1:8200 (no trailing
#                               /v1/). Required.
#   VAULT_TOKEN                 Vault auth token used on every
#                               request. Required. In dev this is
#                               the value of VAULT_DEV_ROOT_TOKEN_ID
#                               above; production uses a token issued
#                               via AppRole / Kubernetes auth.
#   VAULT_TRANSIT_PATH          Mount path of the Transit secrets
#                               engine. Default: transit.
#   VAULT_REQUEST_TIMEOUT_SECS  Per-request timeout. Default: 5.
VAULT_ADDR=http://127.0.0.1:8200
VAULT_TOKEN=dev-only-root


# -----------------------------------------------------------------------------
# Required: SWIYU Identifier Registry
# -----------------------------------------------------------------------------
#
# The management API's worker calls into the SWIYU Identifier Registry on
# every issuer-lifecycle saga step that publishes a DIDLog entry (create,
# rotate-keys, deactivate). `issuer_lifecycle_smoke` also reads these to
# verify the DIDLog after each phase. Both variables are also defined in
# the workspace-root .env.example so `didtool` and the issuer binaries
# share a single set of credentials.
#
# `partner_id` is *not* an env var here: it is a per-tenant attribute in
# the `tenants` table. The worker loads it for the tenant that owns the
# issuer being processed.

# Base URL of the SWIYU Identifier Registry API.
SWIYU_IDENTIFIER_REGISTRY_URL=https://identifier-reg-api.trust-infra.swiyu-int.admin.ch

# Bearer token for the registry API.
SWIYU_ACCESS_TOKEN=


# -----------------------------------------------------------------------------
# Optional (with sensible defaults baked into the binary)
# -----------------------------------------------------------------------------

# -----------------------------------------------------------------------------
# issuer-mgmt binary (management API)
# -----------------------------------------------------------------------------

# Listen address of the issuer-mgmt HTTP server. Default: 0.0.0.0:8080.
BIND_ADDR=0.0.0.0:8080


# -----------------------------------------------------------------------------
# issuer-oidc binary (wallet-facing OIDC API)
# -----------------------------------------------------------------------------

# Listen address of the issuer-oidc HTTP server. Default: 0.0.0.0:8081.
# Distinct from BIND_ADDR so both binaries can run side by side in
# local dev. In production a reverse proxy fronts both binaries on
# the same external host (see specs/impl_api_oidc.md, Deployment
# topology), so wallets and business apps see one URL.
BIND_ADDR_OIDC=0.0.0.0:8081

# Lifetime of an access token minted at POST /token, in seconds.
# Default: 300 (5 minutes). Must be a positive integer.
ACCESS_TOKEN_TTL_SECONDS=300

# Lifetime of a c_nonce minted at POST /token, in seconds. Default:
# 300 (5 minutes). Must be a positive integer. Equal to
# ACCESS_TOKEN_TTL_SECONDS at v0.1.x; rotated independently when
# batch credential issuance arrives.
C_NONCE_TTL_SECONDS=300


# -----------------------------------------------------------------------------
# Shared between both binaries
# -----------------------------------------------------------------------------

# Public base URL the wallet sees. Embedded in the management API's
# offer_deeplink and into the OIDC binary's issuer metadata. Wallets
# fetch the credential offer JSON from
#   <ISSUER_BASE_URL>/i/<issuer-id>/credential-offer/<offer-id>
# Both binaries must agree on this value because the deeplink the
# management binary publishes resolves into the OIDC binary's
# routes; in production a reverse proxy fronts both on the same
# host. Set this to the externally reachable URL in any
# non-localhost deployment. Default: http://localhost:8080.
ISSUER_BASE_URL=http://localhost:8080

# Authentication.
#
# As of v0.1.2 every management-API request must carry an
# Authorization: Bearer tok_<base58> header. The migration
# 20260502_000003_api_tokens.sql seeds one well-known dev token for
# the seeded tenant 4Mk7yK5pQR7sN3, so out-of-the-box `cargo run`
# plus the test commands in test-commands.txt work without minting
# a token first:
#
#   tok_DevDevDevDevDevDevDevDevDevDevDevDevDevDe
#
# This token is alpha/beta-only by policy. To mint a fresh token
# for a tenant, use:
#
#   cargo run --bin issuer-mgmt -- mint-token \
#     --tenant <bare-tenant-id> --name <label> [--expires-in 30d]


# Tracing filter passed to tracing-subscriber's EnvFilter. Examples:
#   info                            # quieter
#   info,swiyu_issuer=debug         # debug for our crate, info elsewhere
#   trace                           # everything (very noisy)
# Default: whatever EnvFilter::from_default_env() returns when unset
# (typically nothing logs). Set explicitly during development.
RUST_LOG=info,swiyu_issuer=debug
