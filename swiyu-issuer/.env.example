# Environment variables consumed by swiyu-issuer.
#
# Copy this file to .env in the same directory and adjust values as
# needed. .env is gitignored at the workspace root.
# direnv loads .env automatically on cd via the sibling .envrc.
#
# -----------------------------------------------------------------------------
# Required: database
# -----------------------------------------------------------------------------
#
# DATABASE_URL is what the binary actually reads. The four
# POSTGRES_* variables below it are read by docker-compose.yml so a
# `docker compose up -d` brings up a Postgres matching this URL.
#
# Keep DATABASE_URL consistent with the four POSTGRES_* values: if
# you change a credential, change it in both places. The duplication
# is intentional — the binary uses the standard DATABASE_URL shape
# (the convention production deployments inject), while compose
# requires components.

# PostgreSQL connection string used by the management API and any
# OIDC-side binary. Format:
#   postgres://<user>:<password>@<host>:<port>/<database>
DATABASE_URL=postgres://swiyu_issuer:swiyu_issuer@localhost:5433/swiyu_issuer

# Database connection components — read by docker-compose.yml.
# Compose falls back to these same defaults if .env is absent, so a
# fresh checkout works without copying this file first.
POSTGRES_USER=swiyu_issuer
POSTGRES_PASSWORD=swiyu_issuer
POSTGRES_DB=swiyu_issuer
POSTGRES_HOST_PORT=5433


# -----------------------------------------------------------------------------
# HashiCorp Vault dev container — read by docker-compose.yml
# -----------------------------------------------------------------------------
#
# docker-compose.yml brings up a HashiCorp Vault container in dev
# mode (in-memory, unsealed, single fixed root token) and enables
# the Transit secrets engine. State is wiped on every container
# restart. Used by VaultSigningEngine in development and integration
# tests; production deployments use a real, sealed Vault.

VAULT_DEV_ROOT_TOKEN_ID=dev-only-root

# Signing-engine backend selected by the binary at startup.
#   dev    — DevSigningEngine, stores private keys unencrypted in
#            Postgres. Default. Suitable for local dev only.
#   vault  — VaultSigningEngine, uses HashiCorp Vault Transit. Reads
#            VAULT_ADDR / VAULT_TOKEN below; private keys never leave
#            Vault.
SIGNING_ENGINE=dev

# -----------------------------------------------------------------------------
# Secret-encryption-engine selection — symmetric encryption of small
# application secrets (OAuth2 refresh tokens, OAuth2 client secrets) at rest.
# -----------------------------------------------------------------------------
#
# Independent of SIGNING_ENGINE above: signing keys and symmetric secrets
# travel through different surfaces, and a deployment may pair (dev signing
# + dev secrets) for local work or (vault signing + vault secrets) for
# production. Mixing — e.g. vault signing + dev secrets — is allowed but
# unusual.
#
# SECRET_ENCRYPTION_ENGINE selects the backend:
#   dev    — DevSecretEncryptionEngine, AES-256-GCM under HKDF-derived
#            keys from a single in-process master key. Default. Suitable
#            for local dev only — the master key sits in this env var.
#   vault  — VaultSecretEncryptionEngine, AES-256-GCM via HashiCorp
#            Vault Transit. Reuses VAULT_ADDR, VAULT_TOKEN, and
#            VAULT_REQUEST_TIMEOUT_SECS from the shared Vault block
#            below; reads its own Transit mount path from
#            SECRET_ENCRYPTION_VAULT_TRANSIT_PATH (defaults to
#            `transit`, same as the signing engine). Per-key
#            provisioning is an operator step (the engine never
#            creates Transit keys).
SECRET_ENCRYPTION_ENGINE=dev

# Required when SECRET_ENCRYPTION_ENGINE=dev. Base64 (standard or URL-safe,
# with or without padding) of exactly 32 random bytes — the master key.
# The dev compose stack and CI use the value below, which encodes the
# 32-byte ASCII string `dev-secret-management-master-key`. It is well-known
# and must NEVER be reused in any non-dev environment.
#
# Rotating this value invalidates every existing ciphertext (HKDF-derived
# keys change). The dev compose stack wipes the database between runs, so
# rotation is safe there; if you have a populated dev database with
# encrypted columns, expect to lose them when this value changes.
SECRET_ENCRYPTION_DEV_MASTER_KEY=ZGV2LXNlY3JldC1tYW5hZ2VtZW50LW1hc3Rlci1rZXk=

# Vault client config — read by the binary when SIGNING_ENGINE=vault
# and/or SECRET_ENCRYPTION_ENGINE=vault.
#
# Server identity (VAULT_ADDR, VAULT_TOKEN, VAULT_REQUEST_TIMEOUT_SECS)
# is shared by both engines: a single deployment points at one Vault
# server with one auth token. The Transit mount path is engine-scoped
# so signing keys and secret-encryption keys can live under different
# mounts with different ACL policies; both knobs default to `transit`
# so a single-mount setup needs no overrides.
#
#   VAULT_ADDR                          Base URL of the Vault server,
#                                       e.g. http://127.0.0.1:8200 (no
#                                       trailing /v1/). Required when
#                                       either engine is `vault`.
#   VAULT_TOKEN                         Vault auth token used on every
#                                       request. Required when either
#                                       engine is `vault`. In dev this
#                                       is the value of
#                                       VAULT_DEV_ROOT_TOKEN_ID above;
#                                       production uses a token issued
#                                       via AppRole / Kubernetes auth.
#   VAULT_REQUEST_TIMEOUT_SECS          Per-request timeout, shared by
#                                       both engines. Default: 5.
#   SIGNING_VAULT_TRANSIT_PATH          Transit mount path used by the
#                                       signing engine. Default: transit.
#   SECRET_ENCRYPTION_VAULT_TRANSIT_PATH Transit mount path used by the
#                                       secret-encryption engine.
#                                       Default: transit.
VAULT_ADDR=http://127.0.0.1:8200
VAULT_TOKEN=dev-only-root
# SIGNING_VAULT_TRANSIT_PATH=transit
# SECRET_ENCRYPTION_VAULT_TRANSIT_PATH=transit


# -----------------------------------------------------------------------------
# Required: SWIYU registry endpoints
# -----------------------------------------------------------------------------
#
# The management API's worker calls into the SWIYU Identifier Registry on
# every issuer-lifecycle saga step that publishes a DIDLog entry (create,
# rotate-keys, deactivate); `issuer_lifecycle_smoke` reads it back to
# verify the DIDLog after each phase. The Status Registry is the target
# of the management API's status-list publisher, which PUTs signed
# `application/statuslist+jwt` documents on every committed bit-update.
#
# A single OAuth2 access token authenticates against both registries
# (and the trust registry, when present) — see specs/aspect-oauth2.md.
# `partner_id` is *not* an env var here: it is a per-tenant attribute
# in the `tenants` table; the worker loads it for the tenant that owns
# the issuer being processed.

# Base URL of the SWIYU Identifier Registry API.
SWIYU_IDENTIFIER_REGISTRY_URL=https://identifier-reg-api.trust-infra.swiyu-int.admin.ch

# Base URL of the SWIYU Status Registry API.
SWIYU_STATUS_REGISTRY_URL=https://status-reg-api.trust-infra.swiyu-int.admin.ch


# -----------------------------------------------------------------------------
# SWIYU OAuth2 token acquisition
# -----------------------------------------------------------------------------

# OAuth2 token endpoint. Required. Production default below (confirmed
# reachable); override for non-production environments. Read by the
# `swiyu-issuer-mgmtapi` binary at startup and threaded into every
# per-tenant `OAuth2TokenProvider`.
SWIYU_TOKEN_URL=https://keymanager-prd.api.admin.ch/keycloak/realms/APIGW/protocol/openid-connect/token

# Optional. Fraction of an access token's `expires_in` after which
# the runtime pre-emptively refreshes. Must be in [0.5, 0.95]; any
# other value fails fast at startup. Default: 0.75.
# SWIYU_TOKEN_REFRESH_FRACTION=0.75

# Optional. HTTP timeout (seconds) for the OAuth2 token endpoint.
# Default: 15. Must be a positive integer.
# SWIYU_TOKEN_HTTP_TIMEOUT_SECS=15

# -----------------------------------------------------------------------------
# Contributor's dev tenant — read by the `bootstrap-dev-tenant`
# compose service via `swiyu-issuer-cli tenant bootstrap-dev-from-env`.
# -----------------------------------------------------------------------------
#
# Each contributor brings their own SWIYU Business Partner record and
# credentials. On every `docker compose up`, `bootstrap-dev-tenant`
# finds the dev tenant row by DEV_TENANT_PARTNER_ID (creating it if
# missing) and writes the oauth_* columns only-if-empty. A
# runtime-rotated refresh token survives a re-run. To force a full
# resync from env, invoke the CLI directly with `--force`:
#
#   cargo run --bin swiyu-issuer-cli -- tenant bootstrap-dev-from-env --force
#
# API-token minting is left to you:
#
#   cargo run --bin swiyu-issuer-cli -- tenant api-token mint \
#     --tenant <bare-tenant-id> --name dev

# SWIYU Business Partner id (UUID). Required. The bootstrap looks up
# the dev tenant row by this value; UNIQUE on `partner_id` makes the
# match deterministic. Get it from your SWIYU ePortal.
DEV_TENANT_PARTNER_ID=

# Optional display name written to `tenants.display_name` when the
# row is created (or on `--force`). Plain text, free form.
DEV_TENANT_DISPLAY_NAME=

# Optional free-form description written to `tenants.description`
# when the row is created (or on `--force`).
DEV_TENANT_DESCRIPTION=

# OAuth2 client id (ePortal: "customer key"). When set and the dev
# tenant's `oauth_client_id` / `oauth_client_secret` columns are NULL,
# the pair is written into the row. When both columns are already
# populated, the bootstrap leaves them alone. The runtime reads
# `oauth_client_id` per tenant.
#
# Rotate via the CLI when the ePortal issues fresh credentials:
#
#   cargo run --bin swiyu-issuer-cli -- tenant set-oauth-credentials \
#     --tenant <bare-tenant-id> --client-id <new-id> --client-secret-stdin
DEV_TENANT_CLIENT_ID=

# OAuth2 client secret (ePortal: "customer secret"). Treat as a secret.
# Paired with DEV_TENANT_CLIENT_ID above; see that block for the
# seeding / rotation behaviour.
DEV_TENANT_CLIENT_SECRET=

# OAuth2 refresh token from the ePortal (the "renewal token"). When
# set and the dev tenant's `oauth_refresh_token` column is NULL, the
# value is written into the row. When the column is already populated
# (e.g. because the runtime rotated it on a previous run), the
# bootstrap leaves it alone. An empty value silently skips the seed;
# the next worker call then fails with `MissingCredentials`.
#
# Production tenants live in the database, not in this env var. After
# a >7-day cliff or credential rotation, paste a fresh value here and
# `docker compose down -v && docker compose up -d`, or use the CLI
# directly:
#
#   cargo run --bin swiyu-issuer-cli -- tenant import-oauth-refresh-token \
#     --tenant <bare-tenant-id> --token-stdin
DEV_TENANT_REFRESH_TOKEN=


# -----------------------------------------------------------------------------
# Optional (with sensible defaults baked into the binary)
# -----------------------------------------------------------------------------

# -----------------------------------------------------------------------------
# swiyu-issuer-mgmtapi binary (management API)
# -----------------------------------------------------------------------------

# Listen address of the swiyu-issuer-mgmtapi HTTP server. Default:
# 0.0.0.0:8080. Read by the binary when run on the host (`cargo run
# --bin swiyu-issuer-mgmtapi`). When running via docker-compose, the
# compose service forces BIND_ADDR=0.0.0.0:8080 inside the container
# regardless of this value.
BIND_ADDR=0.0.0.0:8080

# Host port the compose `swiyu-issuer-mgmtapi` service publishes on.
# Maps to the container's 8080. Change if 8080 is already in use on
# the host.
ISSUER_MGMT_HOST_PORT=8080


# -----------------------------------------------------------------------------
# swiyu-issuer-oidcapi binary (wallet-facing OIDC API)
# -----------------------------------------------------------------------------

# Listen address of the swiyu-issuer-oidcapi HTTP server. Default:
# 0.0.0.0:8081. Distinct from BIND_ADDR so both binaries can run
# side by side in local dev. In production a reverse proxy fronts
# both binaries on the same external host (see specs/impl_api_oidc.md,
# Deployment topology), so wallets and business apps see one URL.
BIND_ADDR_OIDC=0.0.0.0:8081

# Lifetime of an access token minted at POST /token, in seconds.
# Default: 300 (5 minutes). Must be a positive integer.
ACCESS_TOKEN_TTL_SECONDS=300

# Lifetime of a c_nonce minted at POST /token, in seconds. Default:
# 300 (5 minutes). Must be a positive integer. Equal to
# ACCESS_TOKEN_TTL_SECONDS at v0.1.x; rotated independently when
# batch credential issuance arrives.
C_NONCE_TTL_SECONDS=300

# CORS allowlist for the wallet-facing OIDC endpoints. They are
# called from browsers (e.g. a simulated wallet), so the binary adds
# the CORS headers a browser needs. Unset or `*` allows any origin —
# the dev default, and safe here because the flow's bearer token rides
# in the Authorization header, not cookies, so credentials are never
# allowed. In a non-localhost deployment set an explicit comma-
# separated allowlist of exact origins; a malformed entry fails fast
# at startup:
#   OIDC_CORS_ALLOWED_ORIGINS=https://wallet.example,https://demo.example
# Only the swiyu-issuer-oidcapi binary reads this; the management API
# is backend-to-backend and has no CORS layer.
# OIDC_CORS_ALLOWED_ORIGINS=*

# Public base URL of the wallet-facing OIDC endpoints — the single
# value every wallet-facing URL is built from. swiyu-issuer-mgmtapi
# puts it in each offer deeplink's credential_offer_uri;
# swiyu-issuer-oidcapi puts it in the offer body's credential_issuer
# and in the issuer metadata endpoints the wallet follows next. They
# must agree, or the wallet leaves the deeplink and is sent to the
# wrong host.
#
# In dev the two binaries listen on different host ports with no
# reverse proxy, so this names the OIDC port (8081) — distinct from
# ISSUER_BASE_URL (8080), which addresses the management API. Both
# binaries prefer this var and fall back to ISSUER_BASE_URL when it is
# unset, so a reverse-proxied production deployment (one external host
# for both) can leave it unset and set only ISSUER_BASE_URL.
#
# Also read by the credential-lifecycle smoke (`cargo run --example
# credential_lifecycle_smoke`) to drive the wallet flow against the
# OIDC port.
ISSUER_OIDC_HTTP_URL=http://localhost:8081


# -----------------------------------------------------------------------------
# Shared between both binaries
# -----------------------------------------------------------------------------

# Externally reachable base URL of the management API
# (swiyu-issuer-mgmtapi). In dev that is this binary's own host port
# (8080), distinct from the OIDC port in ISSUER_OIDC_HTTP_URL above.
#
# In a reverse-proxied production deployment both binaries sit behind
# one external host, so this is also the wallet-facing base: leave
# ISSUER_OIDC_HTTP_URL unset and both binaries fall back to this value
# for every wallet-facing URL. Set this to the externally reachable
# URL in any non-localhost deployment. Default: http://localhost:8080.
ISSUER_BASE_URL=http://localhost:8080

# Authentication.
#
# Every management-API request must carry an
# Authorization: Bearer tok_<base58> header. There is no seeded dev
# token; mint one yourself once the dev tenant exists (created on
# `docker compose up` by the `bootstrap-dev-tenant` service via
# `swiyu-issuer-cli tenant bootstrap-dev-from-env`):
#
#   cargo run --bin swiyu-issuer-cli -- tenant api-token mint \
#     --tenant <bare-tenant-id> --name dev [--expires-in 30d]
#
# The bare tenant id is printed by the compose service on every up;
# `docker compose logs bootstrap-dev-tenant` will surface it.


# Tracing filter passed to tracing-subscriber's EnvFilter. Examples:
#   info                            # quieter
#   info,swiyu_issuer=debug         # debug for our crate, info elsewhere
#   debug,sqlx=info,hyper=info,h2=info,reqwest=info,tower=info,tower_http=info
#                                   # smoke-test friendly: debug for our
#                                   # crates, info for noisy deps. The compose
#                                   # `swiyu-issuer-mgmtapi` service falls back
#                                   # to this when RUST_LOG is unset.
#   trace                           # everything (very noisy)
# Default: whatever EnvFilter::from_default_env() returns when unset
# (typically nothing logs). Set explicitly during development.
RUST_LOG=info,swiyu_issuer=debug
