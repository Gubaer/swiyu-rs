# Environment variables for the swiyu-issuer explorer stack.
#
# Copy this file to .env in the same directory; `docker compose up -d`
# auto-loads it. Contributors building from source use
# swiyu-issuer/.env.example instead — that file is the dev counterpart
# of this one and references `cargo run` rather than `docker compose
# run --rm`.
#
# Naming note: variables prefixed DEV_TENANT_* below are historical.
# The seeding machinery (the `bootstrap-dev-tenant` compose service
# calling `swiyu-issuer-cli tenant bootstrap-dev-from-env`) was first
# built for contributors and the prefix stuck. The same code path now
# provisions the explorer's real SWIYU tenant on `docker compose up`;
# the prefix has no audience-specific meaning.


# -----------------------------------------------------------------------------
# Image tag
# -----------------------------------------------------------------------------

# Tag pulled by the compose file for each swiyu-issuer-* image. Defaults
# to the floating `swiyu-beta` — pin to a specific release with
# `IMAGE_TAG=<version>-swiyu-beta`, e.g. `IMAGE_TAG=0.1.12-swiyu-beta`.
# The "-swiyu-beta" suffix is intentional and reflects that both the
# issuer software and the wider SWIYU ecosystem are beta.
IMAGE_TAG=swiyu-beta


# -----------------------------------------------------------------------------
# Required: database
# -----------------------------------------------------------------------------
#
# DATABASE_URL is what each binary reads. The four POSTGRES_* variables
# below it are consumed by docker-compose.yml to spin up a matching
# Postgres. Keep them in sync if you change a credential.

# PostgreSQL connection string used by both binaries. Format:
#   postgres://<user>:<password>@<host>:<port>/<database>
DATABASE_URL=postgres://swiyu_issuer:swiyu_issuer@localhost:5433/swiyu_issuer

# Components read by docker-compose.yml. The compose file falls back to
# these same defaults if .env is absent.
POSTGRES_USER=swiyu_issuer
POSTGRES_PASSWORD=swiyu_issuer
POSTGRES_DB=swiyu_issuer
POSTGRES_HOST_PORT=5433


# -----------------------------------------------------------------------------
# HashiCorp Vault dev container — consumed by docker-compose.yml
# -----------------------------------------------------------------------------
#
# Compose brings up a Vault container in dev mode (in-memory, unsealed,
# single fixed root token) and enables the Transit secrets engine.
# State is wiped on every container restart. For local exploration
# only — production deployments use a real, sealed Vault.

VAULT_DEV_ROOT_TOKEN_ID=dev-only-root

# Signing-engine backend selected by each binary at startup.
#   vault  — VaultSigningEngine, uses HashiCorp Vault Transit. Default
#            in this stack. Reads VAULT_ADDR / VAULT_TOKEN below.
#            Private keys never leave Vault.
#   dev    — DevSigningEngine, stores private keys unencrypted in
#            Postgres. Convenient when Vault is unavailable; not safe
#            for anything beyond local experimentation.
SIGNING_ENGINE=vault

# Secret-encryption backend — symmetric encryption of OAuth2 refresh
# tokens and OAuth2 client secrets at rest. Independent of
# SIGNING_ENGINE.
#   vault  — AES-256-GCM via HashiCorp Vault Transit. Default in this
#            stack.
#   dev    — AES-256-GCM under HKDF-derived keys from an in-process
#            master key. The master key sits in this env var; use only
#            if you've overridden SIGNING_ENGINE to dev as well.
SECRET_ENCRYPTION_ENGINE=vault

# Only used when SECRET_ENCRYPTION_ENGINE=dev (which is not the default).
# Base64 of exactly 32 random bytes — the master key. The value below
# encodes the well-known ASCII string `dev-secret-management-master-key`
# and must NEVER be reused outside local exploration. Rotating it
# invalidates every existing ciphertext.
SECRET_ENCRYPTION_DEV_MASTER_KEY=ZGV2LXNlY3JldC1tYW5hZ2VtZW50LW1hc3Rlci1rZXk=

# Vault client config — read by either binary when SIGNING_ENGINE=vault
# and/or SECRET_ENCRYPTION_ENGINE=vault. In the dev compose stack these
# values point at the in-network Vault container.
VAULT_ADDR=http://127.0.0.1:8200
VAULT_TOKEN=dev-only-root


# -----------------------------------------------------------------------------
# SWIYU registry endpoints
# -----------------------------------------------------------------------------
#
# The defaults below point at the SWIYU integration (INT) environment
# and are fine for exploration. Override only when targeting a
# different SWIYU environment.

# Base URL of the SWIYU Identifier Registry API.
SWIYU_IDENTIFIER_REGISTRY_URL=https://identifier-reg-api.trust-infra.swiyu-int.admin.ch

# Base URL of the SWIYU Status Registry API.
SWIYU_STATUS_REGISTRY_URL=https://status-reg-api.trust-infra.swiyu-int.admin.ch

# OAuth2 token endpoint shared by both registries (and the trust
# registry, when present).
SWIYU_TOKEN_URL=https://keymanager-prd.api.admin.ch/keycloak/realms/APIGW/protocol/openid-connect/token


# -----------------------------------------------------------------------------
# Your SWIYU tenant — filled in once from the ePortal
# -----------------------------------------------------------------------------
#
# On every `docker compose up`, the `bootstrap-dev-tenant` service
# finds the tenant row by DEV_TENANT_PARTNER_ID (creating it if
# missing) and writes the oauth_* columns only-if-empty. A
# runtime-rotated refresh token survives a re-run. To force a full
# resync from env:
#
#   docker compose run --rm swiyu-issuer-cli \
#     tenant bootstrap-dev-from-env --force
#
# API-token minting is left to you (see end of file).

# SWIYU Business Partner id (UUID). Required. Look it up on your SWIYU
# ePortal account.
DEV_TENANT_PARTNER_ID=

# Optional display name written to `tenants.display_name` when the row
# is first created. Plain text, free form.
DEV_TENANT_DISPLAY_NAME=

# Optional free-form description written to `tenants.description` when
# the row is first created.
DEV_TENANT_DESCRIPTION=

# OAuth2 client id (ePortal: "customer key"). When set and the
# tenant's oauth_client_id / oauth_client_secret columns are NULL, the
# pair is written into the row. Rotate via the CLI when the ePortal
# issues fresh credentials:
#
#   docker compose run --rm swiyu-issuer-cli \
#     tenant set-oauth-credentials --tenant <id> \
#     --client-id <new-id> --client-secret-stdin
DEV_TENANT_CLIENT_ID=

# OAuth2 client secret (ePortal: "customer secret"). Treat as a secret.
DEV_TENANT_CLIENT_SECRET=

# OAuth2 refresh token from the ePortal (the "renewal token"). When set
# and the tenant's oauth_refresh_token column is NULL, the value is
# written into the row. Empty value silently skips the seed; the next
# worker call then fails with `MissingCredentials`.
#
# Refresh tokens expire after ~7 days. After a cliff or rotation,
# paste a fresh value here and either `docker compose down -v &&
# docker compose up -d`, or rotate via the CLI without wiping state:
#
#   docker compose run --rm swiyu-issuer-cli \
#     tenant import-oauth-refresh-token --tenant <id> --token-stdin
DEV_TENANT_REFRESH_TOKEN=


# -----------------------------------------------------------------------------
# Networking and logging
# -----------------------------------------------------------------------------

# Public base URL the wallet sees. Embedded in the management API's
# offer_deeplink and the OIDC binary's issuer metadata. Both binaries
# must agree on this value; in a single-host explorer setup the
# default localhost URL works.
ISSUER_BASE_URL=http://localhost:8080

# Host port the swiyu-issuer-mgmtapi service publishes on. Maps to the
# container's 8080. Change if 8080 is already in use on the host.
ISSUER_MGMT_HOST_PORT=8080

# URL where the swiyu-issuer-oidcapi HTTP server is reachable from the
# host. Useful for `curl` smoke checks against /healthz and the
# wallet-facing endpoints. Distinct from ISSUER_BASE_URL because in
# the explorer setup each binary listens on its own host port.
ISSUER_OIDC_HTTP_URL=http://localhost:8081

# Tracing filter passed to tracing-subscriber's EnvFilter. Examples:
#   info                            # quieter
#   info,swiyu_issuer=debug         # debug for our crate, info elsewhere
#   debug,sqlx=info,hyper=info,h2=info,reqwest=info,tower=info,tower_http=info
#                                   # debug for our crates, info for
#                                   # noisy deps. The compose services
#                                   # fall back to this when RUST_LOG
#                                   # is unset.
#   trace                           # everything (very noisy)
RUST_LOG=info,swiyu_issuer=debug


# -----------------------------------------------------------------------------
# Minting an API token (after bootstrap)
# -----------------------------------------------------------------------------
#
# Every management-API request must carry an
# Authorization: Bearer tok_<base58> header. The bootstrap does not
# seed one; mint it yourself once the tenant exists. The bare tenant
# id is printed by the bootstrap service on every up — surface it with
# `docker compose logs bootstrap-dev-tenant`. Then:
#
#   docker compose run --rm swiyu-issuer-cli \
#     tenant api-token mint --tenant <id> --name explorer [--expires-in 30d]
