# Environment variables for didtool.
# Copy this file to .env and fill in the values you need.
# Command-line flags take precedence over environment variables.

# ── Key store ────────────────────────────────────────────────────────────────

# Root directory of the key store (default: ~/.didtool/keys; flag: --keystore).
#DIDTOOL_KEYSTORE=

# ── SWIYU identifier registry ────────────────────────────────────────────────
#
# Consumed by `didtool did create` (registry URL + OAuth2 credentials; partner
# id via flag) to allocate DIDs and publish DIDLog entries.

# Business partner ID (flag: --partner-id).
SWIYU_PARTNER_ID=

# Base URL of the identifier registry API (didtool flag: --registry-url).
SWIYU_IDENTIFIER_REGISTRY_URL=https://identifier-reg-api.trust-infra.swiyu-int.admin.ch

# ── SWIYU OAuth2 credentials (registry writes) ───────────────────────────────
#
# didtool authenticates to the identifier registry by exchanging the refresh
# token below for a short-lived access token at the OAuth2 token endpoint on
# every run (the SWIYU gateway forbids the client_credentials grant). The four
# values come from the ePortal; the access token is no longer pasted by hand.
# Accepted as env vars only — intentionally no --flags to keep secrets out of
# shell history.

# OAuth2 token endpoint (the SWIYU Keycloak realm); must be https. This single
# realm fronts every protected SWIYU API, so the value is the same for the
# integration and production registries.
SWIYU_TOKEN_URL=https://keymanager-prd.api.admin.ch/keycloak/realms/APIGW/protocol/openid-connect/token

# Partner OAuth2 client id.
SWIYU_CLIENT_ID=

# Partner OAuth2 client secret.
SWIYU_CLIENT_SECRET=

# Renewal (refresh) token seeded from the ePortal. didtool does not persist the
# rotated value — re-paste from the ePortal once this one ages out (~7 days).
SWIYU_REFRESH_TOKEN=

# ── SWIYU trust registry (required for `didtool business-entity` subcommands) ─

# Base URL of the trust registry API (flag: --trust-registry-url).
SWIYU_TRUST_REGISTRY_URL=https://trust-reg.trust-infra.swiyu-int.admin.ch

# DID of the SWIYU trust authority (required for `verify-trust`; flag: --trust-issuer).
# Allowlist for trust-statement issuers and the signer of status lists.
SWIYU_TRUST_ISSUER_DID=did:tdw:QmWrXWFEDenvoYWFXxSQGFCa6Pi22Cdsg2r6weGhY2ChiQ:identifier-reg.trust-infra.swiyu-int.admin.ch:api:v1:did:2e246676-209a-4c21-aceb-721f8a90b212
