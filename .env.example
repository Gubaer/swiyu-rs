# Environment variables for didtool.
# Copy this file to .env and fill in the values you need.
# Command-line flags take precedence over environment variables.

# ── Key store ────────────────────────────────────────────────────────────────

# Root directory of the key store (default: ~/.didtool/keys; flag: --keystore).
#DIDTOOL_KEYSTORE=

# ── SWIYU identifier registry ────────────────────────────────────────────────
#
# Consumed by:
#   - `didtool create --swiyu` (registry URL + access token; partner id via flag).
#   - `swiyu-issuer` (the `issuer-mgmt` binary and the `issuer_lifecycle_smoke`
#     example): the management API and the worker call into the SWIYU Identifier
#     Registry to allocate DIDs, publish DIDLog entries, and fetch DIDLogs.
#     `partner_id` is a per-tenant attribute in the issuer DB, so
#     `SWIYU_PARTNER_ID` here is for didtool only.

# Business partner ID — didtool only (flag: --partner-id).
SWIYU_PARTNER_ID=

# Base URL of the identifier registry API (didtool flag: --registry-url).
SWIYU_IDENTIFIER_REGISTRY_URL=https://identifier-reg-api.trust-infra.swiyu-int.admin.ch

# Bearer token for the registry API.
# Accepted as env var only — intentionally no --flag to keep it out of shell history.
SWIYU_ACCESS_TOKEN=

# ── SWIYU trust registry (required for `didtool business-entity` subcommands) ─

# Base URL of the trust registry API (flag: --trust-registry-url).
SWIYU_TRUST_REGISTRY_URL=https://trust-reg.trust-infra.swiyu-int.admin.ch

# DID of the SWIYU trust authority (required for `verify-trust`; flag: --trust-issuer).
# Allowlist for trust-statement issuers and the signer of status lists.
SWIYU_TRUST_ISSUER_DID=did:tdw:QmWrXWFEDenvoYWFXxSQGFCa6Pi22Cdsg2r6weGhY2ChiQ:identifier-reg.trust-infra.swiyu-int.admin.ch:api:v1:did:2e246676-209a-4c21-aceb-721f8a90b212
