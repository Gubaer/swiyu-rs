# BFF listening port
BFF_PORT=3000

# Mgmt API base URL (trailing slash optional)
MGMTAPI_URL=http://localhost:8080

# Mgmt API bearer token for the dev tenant (e.g. tok_DevDevDevDevDev...)
MGMTAPI_TOKEN=tok_REPLACE_ME

# Hardcoded identity surfaced by /api/me until OIDC lands.
DEV_USER_ID=test
DEV_TENANT_NAME=dev

# Directory of built SPA assets to serve as a static fallback. Leave unset
# in dev (where `ng serve` serves the SPA and proxies `/api` here); the
# single-container image sets this to where the build is copied.
# SPA_DIR=/srv/spa
